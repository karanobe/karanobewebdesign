---
---
<section class="services">
  <div class="svc-wrap">
    <span class="reveal label">Services & Pricing</span>
    <h2 class="reveal">Everything you need to <span class="serif">win</span> online</h2>
    <div class="svc-grid stagger">
      <div class="reveal svc-card">
        <div class="svc-tag">One-Time</div>
        <h3>Website Build</h3>
        <div class="svc-price">$500 – $800</div>
        <p class="svc-desc">Single-page site starting at $500. Multi-page site starting at $800. Built fast, built to convert.</p>
        <ul>
          <li>Custom design from premium template</li>
          <li>Mobile-responsive & accessible</li>
          <li>SEO-optimized from day one</li>
          <li>Booking/contact form integration</li>
          <li>Google Maps & Business setup</li>
          <li>Custom domain & SSL</li>
          <li>2 rounds of revisions included</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;justify-content:center;" aria-label="Get started with Website Build">Get Started</a>
      </div>
      <div class="reveal svc-card">
        <div class="svc-tag">Monthly</div>
        <h3>Hosting & Care</h3>
        <div class="svc-price">$50/mo</div>
        <p class="svc-desc">Reliable hosting, uptime monitoring, and ongoing support to keep your site running smoothly.</p>
        <ul>
          <li>Hosting & uptime monitoring</li>
          <li>Monthly content updates</li>
          <li>Google Business optimization</li>
          <li>Monthly analytics report</li>
          <li>Speed & security monitoring</li>
          <li>Priority email support</li>
          <li>Minor design tweaks included</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;justify-content:center;" aria-label="Get started with Hosting &amp; Care">Get Started</a>
      </div>
      <div class="reveal svc-card">
        <div class="svc-tag">One-Time</div>
        <h3>E-Commerce Build</h3>
        <div class="svc-price">$1,500 – $3,000</div>
        <p class="svc-desc">Full online store built on Shopify or custom stack. Priced by scope and complexity.</p>
        <ul>
          <li>Shopify or custom build</li>
          <li>Product catalog & collections</li>
          <li>Secure checkout & payments</li>
          <li>Mobile-optimized storefront</li>
          <li>Inventory & order management</li>
          <li>SEO & speed optimized</li>
          <li>2 rounds of revisions included</li>
        </ul>
        <a href="/contact" class="btn-primary" style="width:100%;justify-content:center;" aria-label="Get started with E-Commerce Build">Get Started</a>
      </div>
    </div>
  </div>
</section>
<style>
  .services{padding:100px 24px}.svc-wrap{max-width:1200px;margin:0 auto}
  .services h2{font-size:clamp(2rem,4vw,3rem);letter-spacing:-0.02em;margin:12px 0 48px}
  .svc-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;align-items:start}@media(max-width:900px){.svc-grid{grid-template-columns:1fr;max-width:440px}}
  .svc-card{background:var(--bg-card);border:1px solid var(--border);border-radius:20px;padding:36px 28px;position:relative}
  .svc-card.highlight{border-color:var(--pop);box-shadow:0 0 60px var(--pop-glow)}
  .svc-pop{position:absolute;top:-1px;left:50%;transform:translateX(-50%);background:var(--pop);color:#fff;font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:4px 16px;border-radius:0 0 10px 10px}
  .svc-tag{font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-muted);margin-bottom:8px;margin-top:4px}
  .svc-card h3{font-size:22px;font-weight:700;letter-spacing:-0.02em;margin-bottom:6px}
  .svc-price{font-size:28px;font-weight:800;letter-spacing:-0.03em;color:var(--text);margin-bottom:12px}
  .svc-desc{font-size:14px;color:var(--text-muted);line-height:1.5;margin-bottom:20px}
  .svc-card ul{list-style:none;margin-bottom:24px}
  .svc-card li{font-size:14px;color:var(--text-dim);padding:6px 0;padding-left:20px;position:relative}
  .svc-card li::before{content:'✓';position:absolute;left:0;color:var(--pop);font-weight:600}
</style>
