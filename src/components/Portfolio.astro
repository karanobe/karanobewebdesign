---
interface CaseStudy { title: string; category: string; description: string; result: string; palette: string; href?: string; image?: string; }
interface Props { cases?: CaseStudy[]; }
const { cases = [
  { title:"Jawandha Injury Law", category:"Personal Injury Law", description:"Full website build for a personal injury law firm — authoritative dark navy design with gold accents, practice area pages, attorney bio, and a prominent free consultation CTA that drives direct calls.", result:"Professional credibility + higher consultation rate", palette:"linear-gradient(135deg,#060e1e,#0d2040)", href:"https://jillaw.com/", image:"/jillaw.png" },
  { title:"Train With Dan", category:"Personal Training", description:"Bold, high-impact single-page site for an Orange County personal trainer — full-bleed gym photography, punchy hero typography, service packages, transformation results, and a streamlined contact flow.", result:"Direct booking inquiries from day one", palette:"linear-gradient(135deg,#0a0a0a,#1a1a1a)", href:"https://trainwithdanww.com/", image:"/trainwithdan.png" },
  { title:"Sprig & Ivy", category:"Wedding & Event Planning", description:"Elegant multi-page site for a luxury Orange County wedding and event planning studio — refined typography, tiered service packages, gallery-forward layout, and a seamless inquiry flow built to convert couples from first visit.", result:"More qualified leads from organic search", palette:"linear-gradient(135deg,#0E1A12,#1C2E1E)", href:"https://sprigandivy.com/", image:"/sprigandivy.png" },
  { title:"Prathaa Design Studio", category:"Luxury Indian Fashion", description:"Sophisticated boutique site for a Corona, CA bridal and party wear studio — warm editorial aesthetic, curated product showcases for bridal lehengas, menswear, and fusion wear, with appointment-based shopping built in.", result:"Appointment bookings from day one", palette:"linear-gradient(135deg,#1A0E0A,#2E1A10)", href:"https://prathaadesignstudio.vercel.app/", image:"/prathaadesignstudio.png" },
] } = Astro.props;
---
<section class="portfolio">
  <div class="port-wrap">
    <span class="reveal label">My Work</span>
    <h2 class="reveal">Sites that <span class="serif">perform</span></h2>
    <div class="port-grid stagger">
      {cases.map(c=>(
        <div class="reveal port-card">
          <div class="port-preview" style={`background:${c.palette};`}>
            {c.image ? <img src={c.image} alt={`${c.title} website design by Karan Oberoi — ${c.category} in Orange County`} width="1600" height="900" loading="lazy" decoding="async" /> : <span>{c.title}</span>}
          </div>
          <div class="port-info">
            <div class="port-cat">{c.category}</div>
            <h3>{c.title}</h3>
            <p>{c.description}</p>
            <div class="port-bottom">
              <div class="port-result"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;stroke:var(--pop);flex-shrink:0;"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>{c.result}</div>
              {c.href && <a href={c.href} target="_blank" rel="noopener noreferrer" class="port-link">View Live <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:13px;height:13px;"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></a>}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
<style>
  .portfolio{padding:100px 24px}.port-wrap{max-width:1200px;margin:0 auto}
  .portfolio h2{font-size:clamp(2rem,4vw,3rem);letter-spacing:-0.02em;margin:12px 0 48px}
  .port-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}@media(max-width:768px){.port-grid{grid-template-columns:1fr}}
  .port-card{background:var(--bg-card);border:1px solid var(--border);border-radius:20px;overflow:hidden;transition:border-color 0.3s,transform 0.3s}.port-card:hover{border-color:var(--border-lt);transform:translateY(-3px)}
  .port-preview{aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--border);overflow:hidden}@supports not (aspect-ratio:16/9){.port-preview{padding-top:56.25%;position:relative}.port-preview>*{position:absolute;inset:0}}
  .port-preview img{width:100%;height:100%;object-fit:cover;object-position:top;display:block}
  .port-preview span{font-family:var(--font-d);font-size:24px;font-style:italic;color:rgba(92,107,85,0.3)}
  .port-info{padding:24px}
  .port-cat{font-size:11px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--pop);margin-bottom:8px}
  .port-card h3{font-size:20px;font-weight:600;margin-bottom:8px;letter-spacing:-0.01em}
  .port-card p{font-size:14px;color:var(--text-muted);line-height:1.6;margin-bottom:14px}
  .port-bottom{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap}
  .port-result{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:var(--pop)}
  .port-link{display:inline-flex;align-items:center;gap:5px;font-size:12px;font-weight:600;color:var(--text-muted);border:1px solid var(--border);padding:6px 12px;border-radius:100px;transition:color 0.2s,border-color 0.2s;white-space:nowrap}.port-link:hover{color:var(--pop);border-color:var(--pop)}
</style>
