<footer class="footer"><div class="footer-in">
  <div class="footer-brand"><div class="footer-logo"><span class="logo-name">Karan Oberoi<span class="logo-dot">.</span></span><em>Web Design</em></div><p>Premium websites for local businesses that actually drive results.</p></div>
  <div class="footer-col"><h4>Pages</h4><a href="/work">Work</a><a href="/services">Services</a><a href="/about">About</a><a href="/contact">Contact</a></div>
  <div class="footer-col"><h4>Services</h4><a href="/services">Website Build</a><a href="/services">Growth Plan</a><a href="/services">Marketing Boost</a></div>
  <div class="footer-col"><h4>Connect</h4><a href="https://www.instagram.com/karanobewebdesign/?hl=en">Instagram</a><a href="mailto:contact@karanobe.com">contact@karanobe.com</a></div>
</div><div class="footer-bot"><span>&copy; {new Date().getFullYear()} Karan Oberoi. All rights reserved.</span></div></footer>
<style>
  .footer{border-top:1px solid var(--border);padding:64px 24px 32px}
  .footer-in{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px}@media(max-width:768px){.footer-in{grid-template-columns:1fr 1fr;gap:32px}}
  .footer-logo{display:flex;flex-direction:column;line-height:1;gap:4px;margin-bottom:12px}.footer-logo .logo-name{font-size:22px;font-weight:800;letter-spacing:-0.03em}.footer-logo .logo-dot{color:var(--pop)}.footer-logo em{font-style:normal;font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:var(--pop)}
  .footer-brand p{font-size:14px;color:var(--text-muted);line-height:1.6;max-width:280px}
  .footer-col h4{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;color:var(--text-dim)}
  .footer-col a{display:block;font-size:14px;color:var(--text-muted);padding:4px 0;transition:color 0.3s}.footer-col a:hover{color:var(--pop)}
  .footer-bot{max-width:1200px;margin:48px auto 0;padding-top:24px;border-top:1px solid var(--border);text-align:center}.footer-bot span{font-size:12px;color:var(--text-muted)}
</style>
