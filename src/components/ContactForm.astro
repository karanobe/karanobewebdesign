---
---
<section class="contact-section">
  <div class="contact-grid">
    <div class="reveal contact-text">
      <h2>Let's build something <span class="serif">great</span></h2>
      <p>Tell me about your business and what you're looking for. I'll get back to you within 24 hours with a personalized plan.</p>
      <div class="c-detail"><strong>Email</strong><a href="mailto:contact@karanobe.com">contact@karanobe.com</a></div>
      <div class="c-detail"><strong>Phone</strong><a href="tel:+17144559007">(714) 455-9007</a></div>
      <div class="c-detail"><strong>Based in</strong><span>Orange County, CA — serving businesses nationwide</span></div>
    </div>
    <div class="reveal contact-form-card">
      <form id="contact-form">
        <div class="form-field"><label>Business Name</label><input type="text" name="business_name" placeholder="Your business name" /></div>
        <div class="form-row">
          <div class="form-field"><label>Your Name</label><input type="text" name="name" placeholder="First and last name" required /></div>
          <div class="form-field"><label>Email</label><input type="email" name="email" placeholder="you@email.com" required /></div>
        </div>
        <div class="form-field"><label>Phone</label><input type="tel" name="phone" placeholder="(000) 000-0000" /></div>
        <div class="form-field"><label>Business Type</label><select name="business_type"><option value="">What kind of business?</option><option>Beauty / Nail Salon</option><option>Barbershop</option><option>Yoga / Pilates / Fitness</option><option>Restaurant / Café</option><option>Med Spa / Wellness</option><option>Real Estate</option><option>Other</option></select></div>
        <div class="form-field"><label>Current Website</label><input type="url" name="current_website" placeholder="https://your-current-site.com (if any)" /></div>
        <div class="form-field"><label>What do you need?</label><textarea name="message" rows="3" placeholder="Tell me about your goals — more bookings? Better Google ranking? A complete redesign?"></textarea></div>
        <!-- Honeypot: hidden from real users, filled only by bots -->
        <div class="hp-field" aria-hidden="true"><label>Leave this empty</label><input type="text" name="_hp" tabindex="-1" autocomplete="off" /></div>
        <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">
          <span class="btn-label">Send Message</span>
          <span class="btn-sending" style="display:none;">Sending…</span>
        </button>
        <p class="form-success" style="display:none;">Message sent! I'll be in touch within 24 hours.</p>
        <p class="form-error" style="display:none;">Something went wrong. Please try again or email me directly.</p>
      </form>
    </div>
  </div>
</section>
<style>
  .contact-section{padding:60px 24px 120px}.contact-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:start}
  @media(max-width:900px){.contact-grid{grid-template-columns:1fr}}
  .contact-text h2{font-size:clamp(1.8rem,3vw,2.4rem);letter-spacing:-0.02em;margin-bottom:16px}.contact-text p{font-size:15px;color:var(--text-dim);line-height:1.7;margin-bottom:32px}
  .c-detail{margin-bottom:16px}.c-detail strong{display:block;font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-dim);margin-bottom:2px}.c-detail span,.c-detail a{font-size:14px;color:var(--text-muted)}.c-detail a:hover{color:var(--pop)}
  .contact-form-card{background:var(--bg-card);border:1px solid var(--border);border-radius:20px;padding:36px 28px}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}@media(max-width:600px){.form-row{grid-template-columns:1fr}}
  .form-field{margin-bottom:16px}.form-field label{display:block;font-size:12px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text-dim);margin-bottom:6px}
  .form-field input,.form-field select,.form-field textarea{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:12px 16px;font-family:var(--font-b);font-size:14px;color:var(--text);transition:border-color 0.3s;outline:none}
  .form-field input:focus,.form-field select:focus,.form-field textarea:focus{border-color:var(--pop)}.form-field select{appearance:none;cursor:pointer}.form-field textarea{resize:vertical;min-height:80px}
  .form-field input::placeholder,.form-field textarea::placeholder{color:var(--text-muted)}
  .form-success{margin-top:16px;font-size:14px;color:#22c55e;font-weight:500}
  .form-error{margin-top:16px;font-size:14px;color:#ef4444;font-weight:500}
  /* Honeypot — visually hidden, not removed from DOM so bots can find it */
  .hp-field{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden;opacity:0;pointer-events:none}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btnLabel = form.querySelector('.btn-label') as HTMLElement;
  const btnSending = form.querySelector('.btn-sending') as HTMLElement;
  const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
  const successMsg = form.querySelector('.form-success') as HTMLElement;
  const errorMsg = form.querySelector('.form-error') as HTMLElement;
  const honeypot = form.querySelector('input[name="_hp"]') as HTMLInputElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check — if filled, silently bail (it's a bot)
    if (honeypot.value.trim() !== '') {
      successMsg.style.display = 'block'; // fake success so bot doesn't retry
      form.reset();
      return;
    }

    btnLabel.style.display = 'none';
    btnSending.style.display = 'inline';
    submitBtn.disabled = true;
    successMsg.style.display = 'none';
    errorMsg.style.display = 'none';

    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('https://submit-form.com/znDadsIij', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(data),
      });
      if (res.ok) {
        successMsg.style.display = 'block';
        form.reset();
      } else {
        errorMsg.style.display = 'block';
      }
    } catch {
      errorMsg.style.display = 'block';
    } finally {
      btnLabel.style.display = 'inline';
      btnSending.style.display = 'none';
      submitBtn.disabled = false;
    }
  });
</script>
