---
import Layout from "../layouts/Layout.astro";import Nav from "../components/Nav.astro";import Footer from "../components/Footer.astro";import "../styles/global.css";
---
<Layout title="Page Not Found — Karan Oberoi Web Design" description="The page you're looking for doesn't exist. Head back to the homepage to explore web design services for Orange County businesses.">
<Nav />
<main>
  <section class="not-found">
    <div class="nf-content">
      <span class="label">404</span>
      <h1>Page not <span class="serif">found</span></h1>
      <p>The page you're looking for doesn't exist or has been moved. Let's get you back on track.</p>
      <div class="nf-ctas">
        <a href="/" class="btn-primary">Back to Home <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        <a href="/contact" class="btn-outline">Contact Me</a>
      </div>
    </div>
  </section>
</main>
<Footer />
</Layout>
<style>
  .not-found{padding:180px 24px 120px;text-align:center}
  .nf-content{max-width:560px;margin:0 auto}
  .not-found h1{font-size:clamp(2.4rem,5vw,3.6rem);letter-spacing:-0.02em;margin:16px 0 16px}
  .not-found p{font-size:17px;color:var(--text-dim);line-height:1.7;margin-bottom:36px}
  .nf-ctas{display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap}
</style>
